# Copy this file to .env and fill in real values for local dev.
# Render reads these from its dashboard (no .env file needed on Render).

# Flask
SECRET_KEY=change-me-to-a-long-random-string
FLASK_DEBUG=1

# Organiser gate (the shared password for /login). Default if unset:
# 'pydublin-2026'. Set this to something stronger for any deployment
# you actually care about.
ORGANISER_PASSWORD=pydublin-2026

# Database - REQUIRED for production to make registrations persist.
# Without this the app falls back to local SQLite, which is FINE for local
# dev but gets wiped on every Render deploy (ephemeral filesystem).
#
# Recommended free option: create a project at https://neon.tech (sign in
# with GitHub) and paste the connection string from the dashboard here.
# DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require
